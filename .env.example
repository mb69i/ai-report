# Atlas Environment Variables
# Copy this to .env and fill in your values

# ── AI Services ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=                          # Optional – leave blank if unused
OLLAMA_BASE_URL=http://localhost:11434   # For offline/local LLM

# ── Backend ───────────────────────────────────────────────────────────────────
ATLAS_HOST=127.0.0.1
ATLAS_PORT=7411
ATLAS_DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Leave blank to use OS keyring (recommended)
ATLAS_ENCRYPTION_KEY=

# ── AI Behavior ───────────────────────────────────────────────────────────────
# Set to "true" to prevent ANY data from being sent to external AI services
ATLAS_OFFLINE_MODE=false

# Set to "false" to allow extracted data to be sent to AI for analysis
ATLAS_AI_DATA_PRIVACY=true
