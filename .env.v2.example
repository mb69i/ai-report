# ──────────────────────────────────────────────────────────────────────────────
# Atlas V2 – Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
ATLAS_DEBUG=true
ATLAS_PORT=7411
ATLAS_HOST=127.0.0.1
ATLAS_SECRET_KEY=change-me-to-a-random-64-char-string

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_secret
POSTGRES_DB=atlas_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://atlas:atlas_secret@localhost:5432/atlas_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ── AI Services ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
ATLAS_OFFLINE_MODE=false
ATLAS_AI_DATA_PRIVACY=true

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Storage ───────────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=atlas-reports
S3_REGION=us-east-1

# ── Security ──────────────────────────────────────────────────────────────────
ATLAS_ENCRYPTION_KEY=
